{
  "name": "sql-hidden-cost",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "npm run benchmark:score && npm run benchmark:bundle",
    "deploy": "npx wrangler deploy",
    "deploy:pages": "npx wrangler pages deploy prototypes/lab-console --project-name=llm-friendly-bench",
    "proof:all": "npm run proof:run && npm run proof:validate && npm run proof:gates && npm run proof:bundle && npm run proof:no-mock",
    "proof:fixture": "node scripts/generate-fixtures.mjs",
    "proof:run": "node scripts/run-local-proof.mjs",
    "proof:gates": "node scripts/check-proof-gates.mjs prototypes/lab-console/replays/order-exception-codex-v1-candidate.json",
    "proof:test-gates": "node scripts/test-proof-gates.mjs",
    "proof:verified": "node scripts/promote-verified-replay.mjs && node prototypes/lab-console/validate-replay-artifact.mjs prototypes/lab-console/replays/order-exception-codex-v1-verified.json && node scripts/check-proof-gates.mjs prototypes/lab-console/replays/order-exception-codex-v1-verified.json && npm run proof:bundle && npm run proof:no-mock",
    "proof:bundle": "node scripts/build-public-evidence-bundle.mjs",
    "proof:no-mock": "node scripts/check-no-mock-data.mjs",
    "proof:mongo:db": "node scripts/run-mongodb-local-proof.mjs",
    "proof:postgres:db": "node scripts/run-postgres-local-proof.mjs",
    "proof:validate": "node prototypes/lab-console/validate-replay-artifact.mjs prototypes/lab-console/replays/order-exception-codex-v1-candidate.json",
    "instrumented:prepare": "node scripts/prepare-instrumented-run.mjs all",
    "instrumented:codex:mongo": "node scripts/run-instrumented-codex.mjs mongo",
    "instrumented:codex:postgres": "node scripts/run-instrumented-codex.mjs postgres",
    "instrumented:codex:all": "npm run instrumented:prepare && SKIP_PREPARE=1 npm run instrumented:codex:mongo && SKIP_PREPARE=1 npm run instrumented:codex:postgres && node scripts/score-instrumented-runs.mjs",
    "instrumented:score": "node scripts/score-instrumented-runs.mjs",
    "benchmark:validate": "node scripts/benchmark-validate.mjs",
    "benchmark:prepare": "node scripts/benchmark-prepare.mjs --require-failing-before",
    "benchmark:design-review": "node scripts/benchmark-design-review.mjs",
    "benchmark:run": "node scripts/benchmark-run.mjs",
    "benchmark:score": "node scripts/benchmark-score.mjs",
    "benchmark:bundle": "node scripts/benchmark-build-public-bundle.mjs",
    "benchmark:bundle:v2": "node scripts/benchmark-build-public-bundle-v2.mjs",
    "benchmark:gates": "node scripts/benchmark-gates.mjs",
    "benchmark:test-gates": "node scripts/test-benchmark-gates.mjs",
    "benchmark:ui:test": "node scripts/benchmark-ui-test.mjs",
    "benchmark:all": "npm run benchmark:validate && npm run benchmark:prepare && npm run benchmark:design-review && npm run benchmark:score && npm run benchmark:bundle && npm run benchmark:gates && npm run benchmark:test-gates && npm run benchmark:ui:test",
    "db:up": "docker compose up -d mongodb postgres",
    "db:up:mongo": "docker compose up -d mongodb",
    "db:up:postgres": "docker compose up -d postgres",
    "db:seed": "node scripts/seed-local-databases.mjs all",
    "db:seed:mongo": "node scripts/seed-local-databases.mjs mongo",
    "db:seed:postgres": "node scripts/seed-local-databases.mjs postgres",
    "prototype:lab": "python3 -m http.server 4173 --bind 127.0.0.1 --directory prototypes/lab-console"
  },
  "dependencies": {
    "mongodb": "^7.3.0",
    "pg": "^8.22.0"
  }
}
