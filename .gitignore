.DS_Store
.env
.env.*
.tmp/
.wrangler/
node_modules/
**/node_modules/
**/.git/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.superpowers/
.claude/
# AST-Bench v3 live-run artifacts: publish everything auditable (manifests,
# diffs, test logs, prompts, full agent transcripts, and live-DB snapshots) so
# the benchmark is fully reproducible. Only the per-run agent WORKSPACE is
# ignored — it contains a symlinked node_modules and is regenerable from the
# committed inputs.
benchmark/runs-v3/**/workspace/
benchmark/.prove-v3/
benchmark/.cheat-test/
# Build-Bench live-run artifacts: same policy as v3 — publish everything
# auditable, ignore the regenerable per-run workspace.
benchmark/runs-buildbench/**/workspace/
benchmark/.prove-buildbench/
benchmark/runs-brownfield/**/workspace/
benchmark/.prove-brownfield/
benchmark/runs-complex/**/workspace/
benchmark/runs-enterprise/**/workspace/
