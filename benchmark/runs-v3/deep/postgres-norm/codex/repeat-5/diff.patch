+function toIso(value) {
+  return value instanceof Date ? value.toISOString() : String(value);
+}
+
+async function readFactsFromDb(db) {
+  const account = (await db.query("SELECT * FROM accounts LIMIT 1")).rows[0];
+  const normalizeNumbers = (rows, field) =>
+    rows.map((row) => ({
+      ...row,
+      [field]: row[field] == null ? row[field] : Number(row[field])
+    }));
+
+  const invoices = normalizeNumbers(
+    (await db.query("SELECT invoice_id, amount_cents, due_date, status FROM invoices")).rows,
+    "amount_cents"
+  ).map((invoice) => ({
+    invoiceId: invoice.invoice_id,
+    amountCents: invoice.amount_cents,
+    dueDate: toIso(invoice.due_date),
+    status: invoice.status
+  }));
+
+  const shipments = (await db.query("SELECT shipment_id, sla_date, delivered_date, status FROM shipments")).rows.map((shipment) => ({
+    shipmentId: shipment.shipment_id,
+    slaDate: toIso(shipment.sla_date),
+    deliveredDate: shipment.delivered_date ? toIso(shipment.delivered_date) : null,
+    status: shipment.status
+  }));
+
+  const regulatoryFlags = (await db.query("SELECT flag_id, type, status FROM regulatory_flags")).rows.map((flag) => ({
+    flagId: flag.flag_id,
+    type: flag.type,
+    status: flag.status
+  }));
+
+  const supportCases = (await db.query("SELECT case_id, severity, status FROM support_cases")).rows.map((supportCase) => ({
+    caseId: supportCase.case_id,
+    severity: supportCase.severity,
+    status: supportCase.status
+  }));
+
+  const usage = (await db.query("SELECT prior_period_units, current_period_units FROM usage_periods LIMIT 1")).rows[0] || {};
+
+  return {
+    account: {
+      accountId: account.account_id,
+      name: account.name,
+      tier: account.tier,
+      region: account.region
+    },
+    contract: {},
+    contacts: [],
+    invoices,
+    shipments,
+    regulatoryFlags,
+    supportCases,
+    usage: {
+      priorPeriodUnits: Number(usage.prior_period_units),
+      currentPeriodUnits: Number(usage.current_period_units)
+    }
+  };
+}
+
+function dueAt1600Utc(now) {
+  const dueAt = new Date(now);
+  dueAt.setUTCHours(16, 0, 0, 0);
+  if (Date.parse(now) > dueAt.getTime()) {
+    dueAt.setUTCDate(dueAt.getUTCDate() + 1);
+  }
+  return dueAt.toISOString();
+}
 
 export async function run(now = "2026-06-18T12:00:00.000Z") {
