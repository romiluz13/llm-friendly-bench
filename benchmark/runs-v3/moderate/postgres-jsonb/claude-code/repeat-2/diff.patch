+function evaluateRisks(doc, nowMs) {
+  const fired = {};
+
+  const overdueInvoice = (doc.invoices || []).find(
+    (inv) => inv.status !== "paid" && Date.parse(inv.dueDate) < nowMs && inv.amountCents >= 2_500_000
+  );
+  if (overdueInvoice) fired.invoice = overdueInvoice;
+
+  const lateShipment = (doc.shipments || []).find(
+    (sh) => !sh.deliveredDate && Date.parse(sh.slaDate) < nowMs
+  );
+  if (lateShipment) fired.shipment = lateShipment;
+
+  const openReg = (doc.regulatoryFlags || []).find((flag) => flag.status === "open");
+  if (openReg) fired.regulatory = openReg;
+
+  const escalatedSupport = (doc.supportCases || []).find(
+    (c) => c.status === "open" && ["high", "critical"].includes(c.severity)
+  );
+  if (escalatedSupport) fired.support = escalatedSupport;
+
+  const usage = doc.usage || {};
+  if (
+    typeof usage.priorPeriodUnits === "number" &&
+    typeof usage.currentPeriodUnits === "number" &&
+    usage.priorPeriodUnits > 0 &&
+    usage.currentPeriodUnits <= usage.priorPeriodUnits * 0.7
+  ) {
+    fired.usage = usage;
+  }
+
+  return fired;
+}
 
