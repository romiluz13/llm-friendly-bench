+import { withDb } from "./db.mjs";
+import { RULES, ownersOf, signalsOf } from "./derive.mjs";
+
+function toFacts(account) {
+  return {
+    account: {
+      accountId: account._id ?? account.accountId,
+      name: account.name,
+      tier: account.tier,
+      region: account.region
+    },
+    contract: account.contract,
+    contacts: account.contacts ?? [],
+    invoices: account.invoices ?? [],
+    shipments: account.shipments ?? [],
+    regulatoryFlags: account.regulatoryFlags ?? [],
+    supportCases: account.supportCases ?? [],
+    usage: account.usage ?? {}
+  };
+}
+
+function dueAt(now) {
+  const d = new Date(now);
+  d.setUTCHours(16, 0, 0, 0);
+  return d;
+}
 
 export async function run(now = "2026-06-18T12:00:00.000Z") {
-  // TODO: implement against the live database in cfg.
-  throw new Error("workflow not implemented");
+  await withDb(async (db) => {
+    const account = await db.collection("accounts").findOne({});
+    if (!account) {
+      throw new Error("No account document found");
+    }
+
+    const facts = toFacts(account);
+    const signalNames = signalsOf(facts, now);
+    const qualifyingTier = RULES.qualifyingTiers.includes(String(facts.account.tier || "").toLowerCase());
+    const qualifies = qualifyingTier && signalNames.length > 0;
+    const owners = qualifies ? ownersOf(facts, now) : [];
+
+    const state = {
+      status: qualifies ? RULES.escalationStatus : RULES.monitorStatus,
+      next_step: qualifies ? `${owners[0]} recovery review by 16:00` : "Continue standard monitoring.",
+      risk_summary: `${signalNames.length} signals: ${signalNames.join(", ")}`
+    };
+
+    const tasks = qualifies
+      ? owners.map((owner_group) => ({
+          owner_group,
+          title: `${owner_group} recovery review`,
+          due_at: dueAt(now),
+          status: "open"
+        }))
+      : [];
+
+    const customerMessage = qualifies
+      ? {
+          body:
+            "We identified a set of issues affecting your account and our recovery team is actively coordinating the next steps. We will keep you updated as progress is made."
+        }
+      : null;
+
+    const auditEvent = qualifies
+      ? {
+          event: "Customer-visible recovery workflow activated.",
+          customer_visible: true
+        }
+      : null;
+
+    await Promise.all([
+      db.collection("workflow_state").deleteMany({}),
+      db.collection("owner_tasks").deleteMany({}),
+      db.collection("customer_messages").deleteMany({}),
+      db.collection("audit_events").deleteMany({})
+    ]);
+
+    const writes = [
+      db.collection("workflow_state").insertOne(state)
+    ];
+    if (tasks.length > 0) {
+      writes.push(db.collection("owner_tasks").insertMany(tasks));
+    }
+    if (customerMessage) {
+      writes.push(db.collection("customer_messages").insertOne(customerMessage));
+    }
+    if (auditEvent) {
+      writes.push(db.collection("audit_events").insertOne(auditEvent));
+    }
+
+    await Promise.all(writes);
+  });
 }
 
 if (import.meta.url === `file://${process.argv[1]}`) {
