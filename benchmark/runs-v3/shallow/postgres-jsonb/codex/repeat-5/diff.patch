+  await withDb(async (c) => {
+    await c.query("BEGIN");
+    try {
+      const result = await c.query("SELECT account_id, doc FROM accounts LIMIT 1");
+      const row = result.rows[0];
+      if (!row) throw new Error("No account facts found");
+
+      const facts = buildFacts(row);
+      const accountId = facts.account.accountId;
+      const requestId = facts.request.requestId || `req-${accountId}`;
+      const title = facts.account.name || accountId;
+      const qualified = qualifies(facts, now);
+      const signals = deriveSignals(facts, now);
+      const owners = qualified ? deriveOwners(facts, now) : [];
+      const status = qualified ? RULES.escalationStatus : RULES.monitorStatus;
+      const nextStep = qualified ? `${owners[0]} recovery review by 16:00` : "Continue standard monitoring.";
+      const riskSummary = `${signals.length} signals: ${signals.map((signal) => signal.name).join(", ")}`;
+
+      await resetOutputs(c);
+
+      await c.query(
+        "INSERT INTO workflow_state (request_id, account_id, title, status, next_step, risk_summary) VALUES ($1, $2, $3, $4, $5, $6)",
+        [requestId, accountId, title, status, nextStep, riskSummary]
+      );
+
+      for (const ownerGroup of owners) {
+        await c.query(
+          "INSERT INTO owner_tasks (request_id, account_id, owner_group, title, due_at, status) VALUES ($1, $2, $3, $4, $5, $6)",
+          [requestId, accountId, ownerGroup, `${ownerGroup} recovery owner task`, now, "open"]
+        );
+      }
+
+      if (qualified) {
+        await c.query(
+          "INSERT INTO customer_messages (request_id, account_id, body) VALUES ($1, $2, $3)",
+          [
+            requestId,
+            accountId,
+            "Our team has opened a priority recovery effort on your account and will follow up shortly."
+          ]
+        );
+        await c.query(
+          "INSERT INTO audit_events (request_id, account_id, event, occurred_at, customer_visible) VALUES ($1, $2, $3, $4, $5)",
+          [requestId, accountId, "escalation_opened", now, true]
+        );
+      }
+
+      await c.query("COMMIT");
+    } catch (error) {
+      await c.query("ROLLBACK").catch(() => {});
+      throw error;
+    }
+  });
 }
 
 if (import.meta.url === `file://${process.argv[1]}`) {
