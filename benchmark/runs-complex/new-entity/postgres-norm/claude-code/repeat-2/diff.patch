diff --git a/src/shipments.mjs b/src/shipments.mjs
new file mode 100644
index 0000000..480d49e
--- /dev/null
+++ b/src/shipments.mjs
@@ -0,0 +1,24 @@
+import { ensureSchema } from "./schema.mjs";
+
+function rowToShipment(r) {
+  return { shipmentId: r.shipment_id, orderId: r.order_id, carrier: r.carrier, trackingNumber: r.tracking_number, status: r.status, shippedAt: r.shipped_at };
+}
+
+export async function createShipment(client, data) {
+  await ensureSchema(client);
+  const res = await client.query(
+    'INSERT INTO shipments (shipment_id, order_id, carrier, tracking_number, status, shipped_at) VALUES ($1, $2, $3, $4, $5, $6) ON CONFLICT (shipment_id) DO UPDATE SET order_id = EXCLUDED.order_id, carrier = EXCLUDED.carrier, tracking_number = EXCLUDED.tracking_number, status = EXCLUDED.status, shipped_at = EXCLUDED.shipped_at RETURNING *',
+    [data.shipmentId, data.orderId, data.carrier, data.trackingNumber, data.status, data.shippedAt || null]
+  );
+  return rowToShipment(res.rows[0]);
+}
+
+export async function getShipment(client, shipmentId) {
+  const res = await client.query('SELECT * FROM shipments WHERE shipment_id = $1', [shipmentId]);
+  return res.rows[0] ? rowToShipment(res.rows[0]) : null;
+}
+
+export async function getShipmentsByOrder(client, orderId) {
+  const res = await client.query('SELECT * FROM shipments WHERE order_id = $1', [orderId]);
+  return res.rows.map(rowToShipment);
+}
