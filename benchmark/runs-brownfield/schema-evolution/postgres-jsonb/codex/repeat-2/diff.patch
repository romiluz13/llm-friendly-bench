diff --git a/src/accounts.mjs b/src/accounts.mjs
index 9ea3403..de62e0d 100644
--- a/src/accounts.mjs
+++ b/src/accounts.mjs
@@ -1,7 +1,15 @@
 import { ensureSchema } from "./schema.mjs";
 
+function assertValidRiskScore(data) {
+  if (data.riskScore === undefined) return;
+  if (!Number.isInteger(data.riskScore) || data.riskScore < 0 || data.riskScore > 100) {
+    throw new TypeError("riskScore must be an integer from 0 to 100");
+  }
+}
+
 export async function createAccounts(client, data) {
   await ensureSchema(client);
+  assertValidRiskScore(data);
   const doc = { ...data, createdAt: data.createdAt || new Date().toISOString() };
   await client.query('INSERT INTO accounts (account_id, doc) VALUES ($1, $2) RETURNING doc', [doc.accountId, JSON.stringify(doc)]);
   return doc;
@@ -15,6 +23,7 @@ export async function getAccounts(client, id) {
 export async function updateAccounts(client, id, data) {
   const existing = await getAccounts(client, id);
   if (!existing) return null;
+  assertValidRiskScore(data);
   const updated = { ...existing, ...data };
   await client.query('UPDATE accounts SET doc = $1 WHERE account_id = $2 RETURNING doc', [JSON.stringify(updated), id]);
   return updated;
diff --git a/src/schema.mjs b/src/schema.mjs
index 1c7406e..3df36c8 100644
--- a/src/schema.mjs
+++ b/src/schema.mjs
@@ -8,6 +8,32 @@ export async function ensureSchema(client) {
       CONSTRAINT accounts_doc_key_match CHECK (doc->>'accountId' = account_id)
     )
   `);
+  await client.query(`
+    DO $$
+    BEGIN
+      IF NOT EXISTS (
+        SELECT 1
+        FROM pg_constraint
+        WHERE conname = 'accounts_doc_risk_score_valid'
+          AND conrelid = 'accounts'::regclass
+      ) THEN
+        BEGIN
+          ALTER TABLE accounts
+            ADD CONSTRAINT accounts_doc_risk_score_valid CHECK (
+              CASE
+                WHEN NOT doc ? 'riskScore' THEN TRUE
+                WHEN jsonb_typeof(doc->'riskScore') <> 'number' THEN FALSE
+                ELSE (doc->>'riskScore')::numeric BETWEEN 0 AND 100
+                  AND (doc->>'riskScore')::numeric = trunc((doc->>'riskScore')::numeric)
+              END
+            );
+        EXCEPTION
+          WHEN duplicate_object THEN NULL;
+        END;
+      END IF;
+    END
+    $$;
+  `);
   await client.query('CREATE INDEX IF NOT EXISTS idx_accounts_doc_gin ON accounts USING GIN (doc jsonb_path_ops)');
 }
 
