+          jsonb_typeof(doc->'riskScore') = 'number'
+          AND (doc->>'riskScore') ~ '^[0-9]+$'
+          AND (doc->>'riskScore')::integer BETWEEN 0 AND 100
+        )
+      )
     )
   `);
+  await client.query(`
+    DO $$ BEGIN
+      ALTER TABLE accounts ADD CONSTRAINT accounts_doc_risk_score CHECK (
+        NOT doc ? 'riskScore' OR (
+          jsonb_typeof(doc->'riskScore') = 'number'
+          AND (doc->>'riskScore') ~ '^[0-9]+$'
+          AND (doc->>'riskScore')::integer BETWEEN 0 AND 100
+        )
+      );
+    EXCEPTION WHEN duplicate_object THEN NULL;
+    END $$;
+  `);
   await client.query('CREATE INDEX IF NOT EXISTS idx_accounts_doc_gin ON accounts USING GIN (doc jsonb_path_ops)');
 }
 
