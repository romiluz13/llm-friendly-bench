diff --git a/src/accounts.mjs b/src/accounts.mjs
index 9ea3403..a0d094d 100644
--- a/src/accounts.mjs
+++ b/src/accounts.mjs
@@ -1,7 +1,14 @@
 import { ensureSchema } from "./schema.mjs";
 
+function validateRiskScore(data) {
+  if (data.riskScore !== undefined && (!Number.isInteger(data.riskScore) || data.riskScore < 0 || data.riskScore > 100)) {
+    throw new Error("riskScore must be an integer between 0 and 100");
+  }
+}
+
 export async function createAccounts(client, data) {
   await ensureSchema(client);
+  validateRiskScore(data);
   const doc = { ...data, createdAt: data.createdAt || new Date().toISOString() };
   await client.query('INSERT INTO accounts (account_id, doc) VALUES ($1, $2) RETURNING doc', [doc.accountId, JSON.stringify(doc)]);
   return doc;
@@ -15,6 +22,7 @@ export async function getAccounts(client, id) {
 export async function updateAccounts(client, id, data) {
   const existing = await getAccounts(client, id);
   if (!existing) return null;
+  validateRiskScore(data);
   const updated = { ...existing, ...data };
   await client.query('UPDATE accounts SET doc = $1 WHERE account_id = $2 RETURNING doc', [JSON.stringify(updated), id]);
   return updated;
diff --git a/src/schema.mjs b/src/schema.mjs
index 1c7406e..423f334 100644
--- a/src/schema.mjs
+++ b/src/schema.mjs
@@ -5,9 +5,28 @@ export async function ensureSchema(client) {
     CREATE TABLE IF NOT EXISTS accounts (
       account_id TEXT PRIMARY KEY,
       doc        JSONB NOT NULL,
-      CONSTRAINT accounts_doc_key_match CHECK (doc->>'accountId' = account_id)
+      CONSTRAINT accounts_doc_key_match CHECK (doc->>'accountId' = account_id),
