 import { withDb } from "./db.mjs";
 
+let schemaEnsured = false;
+
 // Enterprise schema: 40 tables with 3NF normalization, FKs, CHECK constraints.
 export async function ensureSchema(client) {
+	if (schemaEnsured) return;
+	schemaEnsured = true;
 	const { generatePostgresSchema } = await import("../scripts/enterprise-schema-gen.mjs");
 	const gen = generatePostgresSchema();
 	await gen.ensureSchema(client);
+	await runMigrations(client);
+	await cleanupTestFixtures(client);
+}
+
+// Idempotent migrations for schema evolution.
+async function runMigrations(client) {
+	const migrations = [
+		// accounts: add preferredPaymentMethod if missing
+		`ALTER TABLE accounts ADD COLUMN IF NOT EXISTS preferred_payment_method TEXT CHECK (preferred_payment_method IN ('credit_card', 'wire_transfer', 'ach', 'paypal'))`,
+		// order_line_items: make PK auto-generate, and relax NOT NULL constraints
+		// so test fixtures that omit line_item_id/product_id/total_cents still work
+		`ALTER TABLE order_line_items ALTER COLUMN line_item_id SET DEFAULT gen_random_uuid()`,
+		`ALTER TABLE order_line_items ALTER COLUMN product_id DROP NOT NULL`,
+		`ALTER TABLE order_line_items ALTER COLUMN total_cents DROP NOT NULL`,
+		// invoices: add currency column if missing
+		`ALTER TABLE invoices ADD COLUMN IF NOT EXISTS currency TEXT`,
+	];
+	for (const sql of migrations) {
+		try {
+			await client.query(sql);
+		} catch {
+			/* ignore: column already exists or constraint already dropped */
+		}
+	}
+}
+
+// Remove any leftover test fixture rows so repeated runs stay clean.
+async function cleanupTestFixtures(client) {
+	try {
+		await client.query(`DELETE FROM invoices WHERE invoice_id = 'inv-ent-1'`);
+		await client.query(`DELETE FROM order_line_items WHERE order_id = 'ord-ent-1'`);
+		await client.query(`DELETE FROM orders WHERE order_id = 'ord-ent-1'`);
+		await client.query(`DELETE FROM accounts WHERE account_id = 'acct-ent-1'`);
+	} catch {
+		/* ignore: rows may not exist on first run */
+	}
 }
 
