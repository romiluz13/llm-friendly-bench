+import { ensureSchema, preferredPaymentMethods } from "./schema.mjs";
+
+function validatePreferredPaymentMethod(data) {
+  if (
+    data.preferredPaymentMethod !== undefined &&
+    !preferredPaymentMethods.includes(data.preferredPaymentMethod)
+  ) {
+    throw new Error("preferredPaymentMethod must be one of: credit_card, wire_transfer, ach, paypal");
+  }
+}
 
 export async function createAccount(client, data) {
   await ensureSchema(client);
+  validatePreferredPaymentMethod(data);
   const doc = { ...data };
   await client.query('INSERT INTO accounts (account_id, doc) VALUES ($1, $2) RETURNING doc', [doc.accountId, JSON.stringify(doc)]);
   return doc;
@@ -16,6 +26,7 @@ export async function updateAccount(client, accountId, data) {
   const existing = await getAccount(client, accountId);
   if (!existing) return null;
   const updated = { ...existing, ...data };
+  validatePreferredPaymentMethod(updated);
   await client.query('UPDATE accounts SET doc = $1 WHERE account_id = $2', [JSON.stringify(updated), accountId]);
   return updated;
 }
