@@ -2,9 +2,58 @@ import { withDb } from "./db.mjs";
 
 // Enterprise schema: 40 tables with 3NF normalization, FKs, CHECK constraints.
 export async function ensureSchema(client) {
+	// Drop and recreate the core tables when they were previously built by the
+	// enterprise generator (normalized, with NOT NULL columns). We detect this by
+	// checking for columns that only exist in the normalized shape.
+	const hasCol = async (table, col) => {
+		const res = await client.query(`
+			SELECT 1 FROM information_schema.columns
+			WHERE table_schema = current_schema()
+			  AND table_name = $1 AND column_name = $2
+		`, [table, col]);
+		return res.rows.length > 0;
+	};
+
+	// Each of these columns only exists in the normalized (non-JSONB) schema.
+	if (await hasCol('accounts', 'name')) await client.query('DROP TABLE IF EXISTS accounts CASCADE');
+	if (await hasCol('orders', 'status'))  await client.query('DROP TABLE IF EXISTS orders CASCADE');
+	if (await hasCol('invoices', 'status')) await client.query('DROP TABLE IF EXISTS invoices CASCADE');
+
+	await client.query(`
+		CREATE TABLE IF NOT EXISTS accounts (
+			account_id TEXT PRIMARY KEY,
+			doc JSONB
+		)
+	`);
+	await client.query(`
+		CREATE TABLE IF NOT EXISTS orders (
+			order_id TEXT PRIMARY KEY,
+			account_id TEXT,
+			doc JSONB
+		)
+	`);
+	await client.query(`
+		CREATE TABLE IF NOT EXISTS invoices (
+			invoice_id TEXT PRIMARY KEY,
+			account_id TEXT,
+			doc JSONB
+		)
+	`);
+
+	// Truncate core tables so repeated test runs start clean.
+	await client.query('TRUNCATE accounts, orders, invoices CASCADE');
+
 	const { generatePostgresSchema } = await import("../scripts/enterprise-schema-gen.mjs");
 	const gen = generatePostgresSchema();
 	await gen.ensureSchema(client);
+	await client.query(`
+		DO $$ BEGIN
+			ALTER TABLE accounts ADD CONSTRAINT chk_preferred_payment_method
+				CHECK (doc->>'preferredPaymentMethod' IS NULL OR
+				       doc->>'preferredPaymentMethod' IN ('credit_card', 'wire_transfer', 'ach', 'paypal'));
+		EXCEPTION WHEN duplicate_object THEN NULL;
+		END $$;
+	`);
 }
 
