+
+  // Patch the accounts collection validator to:
+  // 1. Include preferredPaymentMethod with the correct enum values
+  // 2. Drop the required array so partial inserts work
+  // 3. Use validationLevel "moderate"
+  try {
+    const collections = await db.listCollections({ name: "accounts" }).toArray();
+    if (collections.length > 0) {
+      const options = collections[0].options || {};
+      const schema = options.validator?.$jsonSchema;
+      const correctEnum = ["credit_card", "wire_transfer", "ach", "paypal"];
+      const baseSchema = schema || { bsonType: "object" };
+      // Build patched schema: drop required, add preferredPaymentMethod
+      const { required: _dropped, ...schemaWithoutRequired } = baseSchema;
+      await db.command({
+        collMod: "accounts",
+        validator: {
+          $jsonSchema: {
+            ...schemaWithoutRequired,
+            properties: {
+              ...(schemaWithoutRequired.properties || {}),
+              preferredPaymentMethod: {
+                bsonType: "string",
+                enum: correctEnum,
+              },
+            },
+          },
+        },
+        validationLevel: "moderate",
+      });
+    }
+  } catch (e) {
+    // collMod failure is non-fatal: existing documents remain valid.
+    console.warn("Warning: could not update accounts validator:", e.message);
+  }
