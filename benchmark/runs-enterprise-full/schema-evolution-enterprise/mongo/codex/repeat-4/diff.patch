+function validatePreferredPaymentMethod(data) {
+	if (data.preferredPaymentMethod !== undefined && !preferredPaymentMethods.includes(data.preferredPaymentMethod)) {
+		throw new Error(`Invalid preferredPaymentMethod: ${data.preferredPaymentMethod}`);
+	}
+}
