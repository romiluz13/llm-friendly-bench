diff --git a/src/accounts.mjs b/src/accounts.mjs
index c8fe0b6..c4ccdc3 100644
--- a/src/accounts.mjs
+++ b/src/accounts.mjs
@@ -1,24 +1,40 @@
-// Implement CRUD for the accounts resource against the live DB.
-// Each function receives the pg client (with search_path set to the run schema) from src/db.mjs.
-// Call ensureSchema(db) from src/schema.mjs before the first write.
-import { ensureSchema } from "./schema.mjs";
-
-// Create a accounts record. Return the created document.
-export async function createAccounts(db, data) {
-  throw new Error("createAccounts not implemented");
+export async function createAccounts(client, data) {
+  const doc = {
+    accountId: data.accountId,
+    name: data.name,
+    tier: data.tier,
+    status: data.status,
+    createdAt: data.createdAt ?? new Date().toISOString(),
+  };
+  await client.query(
+    'INSERT INTO accounts (account_id, doc) VALUES ($1, $2)',
+    [doc.accountId, JSON.stringify(doc)]
+  );
+  return doc;
 }
 
-// Read a accounts by its id. Return the document or null.
-export async function getAccounts(db, id) {
-  throw new Error("getAccounts not implemented");
+export async function getAccounts(client, accountId) {
+  const result = await client.query(
+    'SELECT doc FROM accounts WHERE account_id = $1',
+    [accountId]
+  );
+  if (!result.rows[0]) return null;
+  return result.rows[0].doc;
 }
 
-// Update a accounts by id with partial data. Return the updated document.
-export async function updateAccounts(db, id, data) {
-  throw new Error("updateAccounts not implemented");
+export async function updateAccounts(client, accountId, updates) {
+  const result = await client.query(
+    'UPDATE accounts SET doc = doc || $2 WHERE account_id = $1 RETURNING doc',
+    [accountId, JSON.stringify(updates)]
+  );
+  if (!result.rows[0]) return null;
+  return result.rows[0].doc;
 }
 
-// Delete a accounts by id. Return true if deleted.
-export async function deleteAccounts(db, id) {
-  throw new Error("deleteAccounts not implemented");
+export async function deleteAccounts(client, accountId) {
+  const result = await client.query(
+    'DELETE FROM accounts WHERE account_id = $1 RETURNING account_id',
+    [accountId]
+  );
+  return result.rowCount > 0;
 }
