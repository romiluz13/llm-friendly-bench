-// Call ensureSchema(db) from src/schema.mjs before the first write.
-import { ensureSchema } from "./schema.mjs";
+function toAccount(row) {
+  return {
+    accountId: row.account_id,
+    name: row.name,
+    tier: row.tier,
+    status: row.status,
+    createdAt: row.created_at,
+  };
+}
 
-// Create a accounts record. Return the created document.
 export async function createAccounts(db, data) {
-  throw new Error("createAccounts not implemented");
+  const { accountId, name, tier, status, createdAt } = data;
+  const res = await db.query(
+    `INSERT INTO accounts (account_id, name, tier, status, created_at)
+     VALUES ($1, $2, $3, $4, $5)
+     RETURNING *`,
+    [accountId, name, tier, status, createdAt ?? new Date()]
+  );
+  return toAccount(res.rows[0]);
 }
 
-// Read a accounts by its id. Return the document or null.
-export async function getAccounts(db, id) {
-  throw new Error("getAccounts not implemented");
+export async function getAccounts(db, accountId) {
+  const res = await db.query(
+    `SELECT * FROM accounts WHERE account_id = $1`,
+    [accountId]
+  );
+  return res.rows[0] ? toAccount(res.rows[0]) : null;
 }
 
-// Update a accounts by id with partial data. Return the updated document.
-export async function updateAccounts(db, id, data) {
-  throw new Error("updateAccounts not implemented");
+export async function updateAccounts(db, accountId, updates) {
+  const fields = [];
+  const values = [];
+  let i = 1;
+  if (updates.name !== undefined)   { fields.push(`name = $${i++}`);   values.push(updates.name); }
+  if (updates.tier !== undefined)   { fields.push(`tier = $${i++}`);   values.push(updates.tier); }
+  if (updates.status !== undefined) { fields.push(`status = $${i++}`); values.push(updates.status); }
+  values.push(accountId);
+  const res = await db.query(
+    `UPDATE accounts SET ${fields.join(', ')} WHERE account_id = $${i} RETURNING *`,
+    values
+  );
+  return toAccount(res.rows[0]);
 }
 
-// Delete a accounts by id. Return true if deleted.
-export async function deleteAccounts(db, id) {
-  throw new Error("deleteAccounts not implemented");
+export async function deleteAccounts(db, accountId) {
+  await db.query(`DELETE FROM accounts WHERE account_id = $1`, [accountId]);
+  return true;
 }
