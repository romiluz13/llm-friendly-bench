{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mongodb.local/sql-hidden-cost/replay-artifact.schema.json",
  "title": "Interactive Proof Lab Replay Artifact",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "artifactId",
    "proofStatus",
    "scenario",
    "task",
    "agent",
    "fairnessContract",
    "outcome",
    "verdict",
    "lanes",
    "scorecard",
    "costProjection",
    "proofPacket",
    "caseFile",
    "caveat"
  ],
  "properties": {
    "schemaVersion": { "type": "string" },
    "artifactId": { "type": "string" },
    "proofStatus": {
      "type": "string",
      "enum": ["candidate", "verified", "incomplete"]
    },
    "scenario": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "variant"],
      "properties": {
        "name": { "type": "string" },
        "variant": { "type": "string" },
        "fixtureVersion": { "type": "string" }
      }
    },
    "task": {
      "type": "object",
      "additionalProperties": false,
      "required": ["headline", "request"],
      "properties": {
        "headline": { "type": "string" },
        "request": { "type": "string" }
      }
    },
    "agent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "constraint"],
      "properties": {
        "name": { "type": "string" },
        "model": { "type": "string" },
        "constraint": { "type": "string" }
      }
    },
    "fairnessContract": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "outcome": {
      "type": "object",
      "additionalProperties": false,
      "required": ["orderId", "statusPill", "before", "after"],
      "properties": {
        "orderId": { "type": "string" },
        "statusPill": { "type": "string" },
        "before": { "$ref": "#/$defs/portalState" },
        "after": { "$ref": "#/$defs/portalState" }
      }
    },
    "verdict": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/labelValue" }
    },
    "lanes": {
      "type": "array",
      "minItems": 2,
      "items": { "$ref": "#/$defs/lane" }
    },
    "scorecard": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/labelValue" }
    },
    "costProjection": {
      "type": "object",
      "additionalProperties": false,
      "required": ["assumptions", "figures"],
      "properties": {
        "assumptions": { "type": "string" },
        "figures": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/labelValue" }
        }
      }
    },
    "dataContract": {
      "type": "object",
      "additionalProperties": false,
      "required": ["label", "mode", "mockDataAllowed", "sourceOfTruth", "runtimeSources"],
      "properties": {
        "label": { "type": "string" },
        "mode": { "type": "string" },
        "mockDataAllowed": { "type": "boolean", "const": false },
        "sourceOfTruth": { "type": "string" },
        "runtimeSources": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["label", "detail", "source", "status"],
            "properties": {
              "label": { "type": "string" },
              "detail": { "type": "string" },
              "source": { "type": "string" },
              "status": { "$ref": "#/$defs/proofItemStatus" }
            }
          }
        }
      }
    },
    "proofPacket": {
      "type": "object",
      "additionalProperties": false,
      "required": ["summary", "items"],
      "properties": {
        "summary": { "type": "string" },
        "items": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/labelValue" }
        }
      }
    },
    "caseFile": {
      "type": "object",
      "additionalProperties": false,
      "required": ["fairnessControls", "designReview", "evidenceLedger"],
      "properties": {
        "fairnessControls": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["label", "value", "status"],
            "properties": {
              "label": { "type": "string" },
              "value": { "type": "string" },
              "status": { "$ref": "#/$defs/proofItemStatus" }
            }
          }
        },
        "designReview": {
          "type": "object",
          "additionalProperties": false,
          "required": ["status", "reviewer", "mongoRationale", "postgresRationale", "tradeoff"],
          "properties": {
            "status": { "$ref": "#/$defs/proofItemStatus" },
            "reviewer": { "type": "string" },
            "mongoRationale": { "type": "string" },
            "postgresRationale": { "type": "string" },
            "tradeoff": { "type": "string" }
          }
        },
        "evidenceLedger": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["claim", "source", "status"],
            "properties": {
              "claim": { "type": "string" },
              "source": { "type": "string" },
              "status": { "$ref": "#/$defs/proofItemStatus" }
            }
          }
        }
      }
    },
    "caveat": { "type": "string" }
  },
  "$defs": {
    "proofItemStatus": {
      "type": "string",
      "enum": ["required", "captured", "verified", "incomplete"]
    },
    "portalState": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "rows"],
      "properties": {
        "title": { "type": "string" },
        "rows": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/labelValue" }
        }
      }
    },
    "lane": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "model", "score", "meters", "schemaNodes", "events"],
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "model": { "type": "string" },
        "score": { "type": "integer", "minimum": 0, "maximum": 100 },
        "meters": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["label", "value", "width"],
            "properties": {
              "label": { "type": "string" },
              "value": { "type": "string" },
              "width": { "type": "integer", "minimum": 0, "maximum": 100 }
            }
          }
        },
        "schemaNodes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name"],
            "properties": {
              "name": { "type": "string" },
              "primary": { "type": "boolean" }
            }
          }
        },
        "events": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["time", "title", "description", "tag"],
            "properties": {
              "time": { "type": "string" },
              "title": { "type": "string" },
              "description": { "type": "string" },
              "tag": { "type": "string" },
              "active": { "type": "boolean" }
            }
          }
        }
      }
    },
    "labelValue": {
      "type": "object",
      "additionalProperties": false,
      "required": ["label", "value"],
      "properties": {
        "label": { "type": "string" },
        "value": { "type": "string" },
        "tone": { "type": "string", "enum": ["good", "warn", "neutral"] }
      }
    }
  }
}
