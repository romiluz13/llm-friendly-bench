{
  "database": "postgres",
  "designStatus": "clean normalized customer-360 relational candidate",
  "principles": [
    "Normalize independent customer, contract, contact, billing, support, usage, compliance, shipment, task, and audit facts.",
    "Use explicit foreign keys for account, contact, order, shipment, invoice, usage, support case, compliance review, escalation, task, and audit relationships.",
    "Keep audit, usage snapshots, support comments, payment risk events, and status history append-only.",
    "Use join tables where ownership, product categories, compliance flags, activities, and escalation tasks can grow independently."
